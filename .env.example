# QueueStorm Investigator — Environment Variables
# Copy this file to .env and fill in your values (never commit .env)

# --- Optional LLM API keys ---
# If set, the service enriches responses using the respective LLM.
# If not set, the service uses deterministic template-based responses.
GEMINI_API_KEY=

# --- Server settings ---
HOST=0.0.0.0
PORT=8000
